{
  "name": "@t4/api",
  "version": "2.0.0",
  "main": "src/index.ts",
  "license": "MIT",
  "scripts": {
    "dev": "wrangler dev",
    "generate": "drizzle-kit generate",
    "migrate": "wrangler d1 migrations apply oracule-db",
    "migrate:local": "wrangler d1 migrations apply oracule-db --local",
    "seed": "wrangler d1 execute oracule-db --file=./seed/seed.sql",
    "seed:local": "wrangler d1 execute oracule-db --local --file=./seed/seed.sql",
    "studio": "drizzle-kit studio",
    "deploy": "wrangler deploy --minify src/worker.ts",
    "test": "vitest run",
    "clean": "rm -rf .turbo node_modules"
  },
  "dependencies": {
    "@hono/trpc-server": "^0.1.0",
    "@trpc/server": "^10.43.2",
    "@tsndr/cloudflare-worker-jwt": "2.2.7",
    "drizzle-orm": "^0.45.1",
    "drizzle-valibot": "^0.4.2",
    "hono": "^3.9.2",
    "jose": "^6.2.1",
    "miniflare": "3.20231025.1",
    "superjson": "1.13.3",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20231025.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.2.2",
    "vitest": "^4.0.18",
    "wrangler": "^4.71.0"
  }
}
